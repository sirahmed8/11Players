rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin check function
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'a7medorabe7@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Community Admin check for a specific player
    function isPlayerCommAdmin(userId) {
      let playerDoc = get(/databases/$(database)/documents/players/$(userId)).data;
      let commId = playerDoc.activeCommunityId;
      return commId != null && get(/databases/$(database)/documents/communities/$(commId)).data.adminUid == request.auth.uid;
    }

    // Players collection
    match /players/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow update: if isAdmin() || (
        request.auth != null && request.auth.uid == userId && 
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['attributes', 'approvedAttributes', 'isVerifiedByAdmin', 'hasWarning', 'isMockData', 'stats', 'overallRating']))
      ) || (
        isPlayerCommAdmin(userId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats', 'overallRating', 'attributes', 'approvedAttributes'])
      );
      allow delete: if isAdmin();
    }

    // Users collection (for notifications)
    match /users/{userId} {
      allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      
      match /notifications/{notificationId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null; // System/anyone can send notification to user inbox
        allow update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Profile edits (pending approvals)
    match /profileEdits/{editId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
    }

    // System configuration
    match /system/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Communities
    match /communities/{communityId} {
      allow read: if request.auth != null;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.adminUid);

      match /players/{userId} {
        allow read: if request.auth != null;
        allow write: if isAdmin() || (request.auth != null && request.auth.uid == get(/databases/$(database)/documents/communities/$(communityId)).data.adminUid) || (request.auth != null && request.auth.uid == userId);
      }
      
      match /requests/{requestId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == requestId;
        allow update, delete: if isAdmin() || (request.auth != null && request.auth.uid == get(/databases/$(database)/documents/communities/$(communityId)).data.adminUid) || (request.auth != null && request.auth.uid == requestId);
      }
      
      match /editRequests/{editId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update, delete: if isAdmin() || (request.auth != null && request.auth.uid == get(/databases/$(database)/documents/communities/$(communityId)).data.adminUid) || (request.auth != null && resource.data.playerId == request.auth.uid);
      }

      match /matches/{matchId} {
        allow read: if request.auth != null;
        allow write: if isAdmin() || (request.auth != null && request.auth.uid == get(/databases/$(database)/documents/communities/$(communityId)).data.adminUid);
      }

      match /settings/{docId} {
        allow read: if request.auth != null;
        allow write: if isAdmin() || (request.auth != null && request.auth.uid == get(/databases/$(database)/documents/communities/$(communityId)).data.adminUid);
      }

      match /chats/{chatId} {
        allow read: if request.auth != null && exists(/databases/$(database)/documents/communities/$(communityId)/players/$(request.auth.uid));
        allow create: if request.auth != null && exists(/databases/$(database)/documents/communities/$(communityId)/players/$(request.auth.uid));
        allow update, delete: if isAdmin() || (request.auth != null && request.auth.uid == get(/databases/$(database)/documents/communities/$(communityId)).data.adminUid) || (request.auth != null && resource.data.senderUid == request.auth.uid);
      }
    }

    // Support Threads
    match /support_threads/{threadId} {
      allow read: if isAdmin() || request.auth.uid == threadId;
      allow create: if request.auth != null && request.auth.uid == threadId;
      allow update, delete: if isAdmin() || request.auth.uid == threadId;
      
      match /messages/{messageId} {
        allow read: if isAdmin() || request.auth.uid == threadId;
        allow create: if request.auth != null && (isAdmin() || request.auth.uid == threadId);
        allow update, delete: if isAdmin() || (request.auth.uid == resource.data.senderUid);
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
