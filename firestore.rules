rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'a7medorabe7@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isCommAdmin(communityId) {
      return request.auth != null && request.auth.uid == get(/databases/$(database)/documents/communities/$(communityId)).data.adminUid;
    }

    function isCommunityMember(communityId) {
      return request.auth != null && exists(/databases/$(database)/documents/communities/$(communityId)/players/$(request.auth.uid));
    }

    // ── Players Collection ──

    match /players/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow update: if isAdmin() || (
        request.auth != null && request.auth.uid == userId &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['attributes', 'approvedAttributes', 'isVerifiedByAdmin', 'hasWarning', 'isMockData', 'stats', 'overallRating', 'peerRatingAvg', 'peerRatingCount']))
      ) || (
        isPlayerCommAdmin(userId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats', 'overallRating', 'attributes', 'approvedAttributes', 'peerRatingAvg', 'peerRatingCount'])
      );
      allow delete: if isAdmin();
    }

    function isPlayerCommAdmin(userId) {
      let playerDoc = get(/databases/$(database)/documents/players/$(userId)).data;
      let commId = playerDoc.activeCommunityId;
      return commId != null && isCommAdmin(commId);
    }

    // ── Users Collection (Notifications) ──

    match /users/{userId} {
      allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == userId);

      match /notifications/{notificationId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        // Authenticated users can create notifications in their own inbox,
        // or admins/community-admins can create notifications in any user's inbox (system notifications)
        allow create: if request.auth != null && (
          request.auth.uid == userId ||
          isAdmin() ||
          (request.resource.data.ratedBy != null) // Allow match-rating notifications from teammates
        );
        allow update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Profile Edits (Pending Approvals) ──

    match /profileEdits/{editId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
    }

    // ── Global Edit Requests ──

    match /editRequests/{editId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin() || (request.auth != null && resource.data.playerId == request.auth.uid);
    }

    // ── Site Feedback ──

    match /site_feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // ── System Configuration ──

    match /system/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Communities ──

    match /communities/{communityId} {
      allow read: if request.auth != null;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() || isCommAdmin(communityId);

      match /players/{userId} {
        allow read: if request.auth != null;
        allow create: if isAdmin() || isCommAdmin(communityId) || (request.auth != null && request.auth.uid == userId);
        allow update: if isAdmin() || isCommAdmin(communityId) ||
          (request.auth != null && request.auth.uid == userId) ||
          (request.auth != null && isCommunityMember(communityId) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['captainVotes']) &&
            request.resource.data.captainVotes is list);
        allow delete: if isAdmin() || isCommAdmin(communityId) || (request.auth != null && request.auth.uid == userId);
      }

      match /requests/{requestId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == requestId;
        allow update, delete: if isAdmin() || isCommAdmin(communityId) || (request.auth != null && request.auth.uid == requestId);
      }

      match /editRequests/{editId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update, delete: if isAdmin() || isCommAdmin(communityId) || (request.auth != null && resource.data.playerId == request.auth.uid);
      }

      match /matches/{matchId} {
        allow read: if request.auth != null;
        allow write: if isAdmin() || isCommAdmin(communityId);

        // Per-match player ratings (stored by rater UID)
        match /ratings/{raterUid} {
          allow read: if request.auth != null;
          allow create, update: if request.auth != null && isCommunityMember(communityId) && request.auth.uid == raterUid &&
            request.resource.data.keys().hasOnly(['ratedBy', 'ratings', 'timestamp', 'matchId']) &&
            request.resource.data.ratedBy == request.auth.uid;
          allow delete: if isAdmin() || isCommAdmin(communityId);
        }
      }

      // Cross-match peer ratings (raterUid_ratedUid composite)
      match /playerRatings/{ratingId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null && isCommunityMember(communityId) &&
          request.auth.uid == request.resource.data.raterUid &&
          request.resource.data.keys().hasOnly(['raterUid', 'ratedUid', 'rating', 'matchId', 'timestamp']) &&
          request.resource.data.rating is number &&
          request.resource.data.rating >= 1 && request.resource.data.rating <= 10;
        allow delete: if isAdmin() || isCommAdmin(communityId);
      }

      match /settings/{docId} {
        allow read: if request.auth != null;
        allow write: if isAdmin() || isCommAdmin(communityId);
      }

      match /chats/{chatId} {
        allow read: if request.auth != null && isCommunityMember(communityId);
        allow create: if request.auth != null && isCommunityMember(communityId);
        allow update, delete: if isAdmin() || isCommAdmin(communityId) || (request.auth != null && resource.data.senderUid == request.auth.uid);
      }
    }

    // ── Support Threads ──

    match /support_threads/{threadId} {
      allow read: if isAdmin() || request.auth.uid == threadId;
      allow create: if request.auth != null && request.auth.uid == threadId;
      allow update, delete: if isAdmin() || request.auth.uid == threadId;

      match /messages/{messageId} {
        allow read: if isAdmin() || request.auth.uid == threadId;
        allow create: if request.auth != null && (isAdmin() || request.auth.uid == threadId);
        allow update, delete: if isAdmin() || (request.auth.uid == resource.data.senderUid);
      }
    }

    // ── Default Deny ──

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
