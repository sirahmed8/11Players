rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin check function
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == 'G8vV7jTvd0VUeRlohrGFyARhiiw1' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Players collection
    match /players/{userId} {
      allow read: if true;
      allow create: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow update: if isAdmin() || (
        request.auth != null && 
        request.auth.uid == userId && 
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['attributes', 'approvedAttributes', 'isVerifiedByAdmin', 'hasWarning', 'stats', 'isMockData']))
      );
      allow delete: if isAdmin();
    }

    // Profile edits (pending approvals)
    match /profileEdits/{editId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
    }

    // System configuration (like matchmaking)
    match /system/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
